{
    "name": "website",
    "type": "module",
    "version": "2.0.0",
    "scripts": {
        "dev": "astro dev",
        "start": "astro preview",
        "build": "astro build",
        "typecheck": "tsc --noEmit",
        "typecheck:w": "pnpm run typecheck --watch",
        "check": "astro check",
        "check:w": "pnpm run check --watch",
        "format": "prettier -w src config",
        "format:check": "prettier --check src/**/*.{js,ts,tsx,astro} config/**/*.ts",
        "lint": "eslint src config",
        "ci:setup-vercel": "vercel pull --yes --environment production --token \"$VERCEL_TOKEN\"",
        "ci:deploy": "vercel deploy --prebuilt --prod --token \"$VERCEL_TOKEN\""
    },
    "dependencies": {
        "@astrojs/mdx": "5.0.2",
        "@astrojs/rss": "4.0.17",
        "@astrojs/sitemap": "3.7.1",
        "@astrojs/vercel": "10.0.2",
        "@fontsource-variable/inter": "5.2.8",
        "astro": "6.0.8",
        "astro-icon": "1.1.5",
        "clsx": "2.1.1",
        "reading-time": "1.5.0",
        "rehype-autolink-headings": "7.1.0",
        "rehype-pretty-code": "0.14.3",
        "rehype-slug": "6.0.0",
        "shiki": "4.0.2",
        "tailwind-merge": "3.5.0",
        "sharp": "0.34.5",
        "ts-pattern": "5.9.0"
    },
    "devDependencies": {
        "@astrojs/check": "0.9.8",
        "@eslint/js": "10.0.1",
        "@tailwindcss/vite": "4.2.2",
        "eslint": "10.1.0",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-astro": "1.6.0",
        "prettier": "3.8.1",
        "prettier-plugin-astro": "0.14.1",
        "tailwindcss": "4.2.2",
        "typescript": "5.7.3",
        "typescript-eslint": "8.57.2",
        "vercel": "39.4.2",
        "@types/node": "24.12.0"
    },
    "packageManager": "pnpm@10.32.1"
}
